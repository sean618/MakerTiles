		(at 39.37 150.876 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "762ab64e-3320-4a25-b634-3f1ed5059090")
	)
	(text "Switch off the battery power but still\nleave the connection to the charger\nso it can be charged via USB"
