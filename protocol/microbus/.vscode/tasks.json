{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-DCMAKE_BUILD_TYPE=Debug",
        "-S", "${workspaceFolder}",
        "-B", "${workspaceFolder}/build"
      ]
    },
    {
      "label": "cmake build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$lldb"],
      "dependsOn": ["cmake configure"]
    },
  ]
}